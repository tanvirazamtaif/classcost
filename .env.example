DATABASE_URL=postgresql://user:password@host:5432/classcost
PORT=3001

# ─── Google Sign-In (existing) ───────────────────────────────────────────────
# Get this from https://console.cloud.google.com/apis/credentials
# Create an OAuth 2.0 Client ID for a Web Application.
VITE_GOOGLE_CLIENT_ID=

# ─── Firebase (Apple + Phone OTP) ────────────────────────────────────────────
# Get these from https://console.firebase.google.com/ → Project Settings → General
# See FIREBASE_SETUP.md for step-by-step instructions.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
