generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String    @id @default(uuid())
  email              String    @unique
  name               String?
  eduType            String?
  institution        String?
  classLevel         String?
  currency           String    @default("BDT")
  pin                String?
  parentPin          String?
  isLoggedIn         Boolean   @default(false)
  profileComplete    Boolean   @default(false)
  onboardingSkipped  Boolean   @default(false)
  onboardingStep     Int       @default(0)
  onboardingComplete Boolean   @default(false)
  profile            Json?
  premiumUntil       DateTime?
  premiumSource      String?
  lastLoginAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  expenses        Expense[]
  semesters       Semester[]
  loans           Loan[]
  settings        Settings?
  coachingCenters CoachingCenter[]
  batches         Batch[]
  privateTutors   PrivateTutor[]
  clubs           Club[]
  events          Event[]
  uniforms        Uniform[]
  educationFees   EducationFee[]
  housings        Housing[]

  // v3 architecture relations
  entities            Entity[]
  trackers            Tracker[]
  obligations         Obligation[]
  ledgerEntries       LedgerEntry[]
  allocationsReceived Allocation[]
  linkedAsParent      LinkedAccount[] @relation("ParentLink")
  linkedAsChild       LinkedAccount[] @relation("ChildLink")
  feeItems            FeeItem[]
  waivers             Waiver[]
  recurringSchedules  RecurringSchedule[]
}

model PromoCode {
  id           String    @id @default(uuid())
  code         String    @unique
  description  String?
  durationDays Int       @default(30)
  maxUses      Int       @default(100)
  usedCount    Int       @default(0)
  active       Boolean   @default(true)
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
}

model Otp {
  id        String   @id @default(uuid())
  email     String
  code      String
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, code])
}

model Expense {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  amount    Float
  note      String?
  date      String
  meta      Json?
  createdAt DateTime @default(now())
}

model Semester {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  courses   Json     @default("[]")
  dropped   Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Loan {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  loanType          String
  purpose           String?
  principal         Float
  annualRate        Float
  tenureMonths      Int
  gracePeriodMonths Int      @default(0)
  lender            String?
  payments          Json     @default("[]")
  startDate         String?
  createdAt         DateTime @default(now())

  ledgerEntries LedgerEntry[]
}

model Settings {
  id            String @id @default(uuid())
  userId        String @unique
  user          User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  notifications Json   @default("{\"enabled\":true,\"canteen\":true,\"transport\":true}")
  privacy       Json   @default("{}")
  promotion     Json   @default("{}")
  customModules Json   @default("[]")
}

model CoachingCenter {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  monthlyFee  Float
  totalMonths Int?
  monthsPaid  Int      @default(0)
  startDate   DateTime
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Batch {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  fee       Float
  frequency String
  isPaid    Boolean   @default(false)
  startDate DateTime
  endDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model PrivateTutor {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tutorName       String
  subject         String
  monthlyFee      Float
  paymentType     String
  sessionsPerWeek Int?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Club {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  institutionName String   @default("")
  name            String
  data            Json?
  fee             Float?
  frequency       String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Event {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  amount    Float
  date      DateTime
  category  String
  isPaid    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Uniform {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  purchaseDate DateTime
  description  String?
  amount       Float
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model EducationFee {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  feeType   String
  data      Json // Full complex fee object (payments, periodStatus, installments, etc.)
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Housing {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  housingType String
  name        String
  data        Json // Full setup object: monthlyRent, deposit, moveInDate, status, etc.
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── V3 ARCHITECTURE ENUMS ─────────────────────────────────────────────────

enum EntityType {
  INSTITUTION
  RESIDENCE
  COACHING
  ABROAD
  PERSONAL_PHASE
}

enum TrackerType {
  SEMESTER
  MONTHLY
  RECURRING_MONTHLY
  RECURRING_YEARLY
  ONE_TIME
  PER_CLASS
  INSTALLMENT_PLAN
  SESSION
  EXAM_CYCLE
  ABROAD_PREP
  CUSTOM
}

enum TrackerStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
  CANCELLED
}

enum ObligationStatus {
  UPCOMING
  DUE
  PENDING
  PARTIAL
  PARTIALLY_PAID
  PAID
  OVERDUE
  WAIVED
  SKIPPED
  CANCELLED
  VOIDED
}

enum LedgerType {
  EXPENSE
  PAYMENT
  INCOME
  SCHOLARSHIP_CASH
  REFUND
  WAIVER_CREDIT
  ADJUSTMENT
  CORRECTION
  TRANSFER
}

enum LedgerDirection {
  DEBIT
  CREDIT
}

enum LedgerStatus {
  CONFIRMED
  POSTED
  PENDING
  VOID
  VOIDED
}

// ─── V3 ARCHITECTURE MODELS ────────────────────────────────────────────────

// Section 1: Entity — represents a real-world place the student pays money to
model Entity {
  id             String     @id @default(cuid())
  userId         String
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  type           EntityType
  name           String
  shortName      String? // DEPRECATED — kept for migration safety
  subType        String?
  eduLevel       String?
  startDate      DateTime?
  endDate        DateTime?
  isActive       Boolean    @default(true)
  archivedAt     DateTime? // DEPRECATED — kept for migration safety
  meta           Json? // DEPRECATED — use metadata
  metadata       Json?
  parentEntityId String? // For club-to-institution linkage
  // Phase 1 — soft links into the curated Institution Data Center (templates).
  // Nullable, no relation/FK by design: existing string-named entities keep
  // working untouched; new entities MAY attach to a curated template.
  institutionId  String? // → Institution.id (curated template)
  branchId       String? // → Branch.id
  sectionId      String? // → Section.id
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  trackers      Tracker[]
  obligations   Obligation[]
  ledgerEntries LedgerEntry[]

  @@index([userId, type])
  @@index([userId, isActive])
  @@index([institutionId])
}

// Section 2: Tracker — a time-bound cost container (e.g. "Fall 2025 semester")
model Tracker {
  id                 String        @id @default(cuid())
  userId             String
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  entityId           String?
  entity             Entity?       @relation(fields: [entityId], references: [id], onDelete: SetNull)
  type               TrackerType
  label              String
  category           String        @default("other") // semester_fee | rent | coaching_monthly | etc.
  cadence            String? // monthly | yearly | per_semester | per_session | once
  startDate          DateTime
  endDate            DateTime?
  status             TrackerStatus @default(ACTIVE)
  meta               Json? // credits, semester number, custom fields
  budgetMinor        Int? // optional budget cap in minor units
  academicPeriodType String? // semester | session | phase | term
  obligationMode     String        @default("pooled") // pooled | fee_linked
  installmentCount   Int? // 1-4 for pooled mode
  grossMinor         Int? // cached gross total of all FeeItems (for display, recomputed on change)
  netMinor           Int? // cached net after waivers (for display, recomputed on change)
  // Phase 2 — frozen post-waiver breakdown {grossMinor, netMinor, totalWaiverMinor, ...}
  // for reports/closure to read a stable figure instead of recomputing.
  profileSnapshot    Json?
  profileFrozenAt    DateTime? // set when a semester closes (Phase 5); null = live/recomputable
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  obligations   Obligation[]
  ledgerEntries LedgerEntry[]
  feeItems      FeeItem[]
  waivers       Waiver[]

  @@index([userId, status])
  @@index([entityId, status])
  @@index([userId, entityId])
}

// Section 3: Obligation — a known upcoming cost (e.g. "Tuition ৳85,000 due Jan 15")
model Obligation {
  id                String           @id @default(cuid())
  userId            String
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  entityId          String?
  entity            Entity?          @relation(fields: [entityId], references: [id], onDelete: SetNull)
  trackerId         String?
  tracker           Tracker?         @relation(fields: [trackerId], references: [id], onDelete: SetNull)
  category          String // from categories registry
  label             String
  amountMinor       Int // total obligation in minor units
  paidMinor         Int              @default(0) // DEPRECATED — derived from ledger, kept for migration safety
  dueDate           DateTime?
  status            ObligationStatus @default(UPCOMING)
  waiverPct         Int              @default(0) // DEPRECATED — use waiverAmountMinor
  waiverAmountMinor Int              @default(0) // Absolute waiver in minor units
  customAmount      Boolean          @default(false) // Phase 2 — user hand-edited this installment; redistribute() must not overwrite it
  waiverReason      String? // "Merit scholarship", "Sports waiver 20%"
  period            String? // "2026-03", "2026-yearly", "spring-2026"
  installmentSeq    Int? // 1, 2, 3 for installment parts
  installmentOf     Int? // total installments (e.g., 3)
  isRecurring       Boolean          @default(false)
  recurrenceRule    String? // iCal RRULE or simple: "MONTHLY", "SEMESTER"
  parentId          String? // self-relation for installment splits
  parent            Obligation?      @relation("InstallmentSplit", fields: [parentId], references: [id])
  installments      Obligation[]     @relation("InstallmentSplit")
  meta              Json?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  ledgerEntries LedgerEntry[]

  @@index([userId, status])
  @@index([trackerId, status])
  @@index([userId, dueDate])
  @@index([userId, category])
  @@index([userId, period])
  @@index([parentId])
}

// Section 4: LedgerEntry — every money movement, immutable record
model LedgerEntry {
  id              String          @id @default(cuid())
  userId          String
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  trackerId       String?
  tracker         Tracker?        @relation(fields: [trackerId], references: [id], onDelete: SetNull)
  obligationId    String?
  obligation      Obligation?     @relation(fields: [obligationId], references: [id], onDelete: SetNull)
  entityId        String?
  entity          Entity?         @relation(fields: [entityId], references: [id], onDelete: SetNull)
  type            LedgerType
  direction       LedgerDirection
  category        String
  subCategory     String?
  amountMinor     Int
  baseAmountMinor Int? // amount in user's home currency, for multi-currency
  currency        String          @default("BDT")
  status          LedgerStatus    @default(POSTED)
  date            DateTime
  note            String?
  receiptUrl      String?
  sourceRef       String? // migration traceability, receipt provenance
  loanId          String?
  loan            Loan?           @relation(fields: [loanId], references: [id], onDelete: SetNull)
  meta            Json?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  allocations Allocation[]

  @@index([userId, date])
  @@index([userId, category])
  @@index([trackerId, date])
  @@index([obligationId])
  @@index([userId, type, date])
  @@index([userId, entityId, date])
  @@index([loanId])
}

// Section 5: Allocation — splits a payment across family members
model Allocation {
  id            String      @id @default(cuid())
  ledgerEntryId String
  ledgerEntry   LedgerEntry @relation(fields: [ledgerEntryId], references: [id], onDelete: Cascade)
  toUserId      String
  toUser        User        @relation(fields: [toUserId], references: [id], onDelete: Cascade)
  amountMinor   Int
  note          String?
  createdAt     DateTime    @default(now())

  @@index([ledgerEntryId])
  @@index([toUserId])
}

// Section 6: LinkedAccount — parent↔child family linking
model LinkedAccount {
  id        String   @id @default(cuid())
  parentId  String
  parent    User     @relation("ParentLink", fields: [parentId], references: [id], onDelete: Cascade)
  childId   String
  child     User     @relation("ChildLink", fields: [childId], references: [id], onDelete: Cascade)
  role      String   @default("viewer") // viewer, editor, admin
  createdAt DateTime @default(now())

  @@unique([parentId, childId])
}

// Section 7: FeeItem — individual fee line items within a tracker/semester
model FeeItem {
  id        String  @id @default(cuid())
  trackerId String
  tracker   Tracker @relation(fields: [trackerId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  label        String // "Tuition", "Lab fee", "Cambridge Physics"
  feeCategory  String // tuition | lab | exam | library | development | registration | deposit | fine | retake | thesis | hostel | transport | activity | medical | custom
  billingBasis String // per_credit | fixed | yearly | one_time | per_subject | per_class | per_exam

  amountMinor Int // Positive = charge. Negative = adjustment/reduction.

  creditCount   Int?
  ratePerCredit Int?
  creditType    String? // standard | lab | retake

  coveragePeriod  String? // "2026" for yearly, "spring-2026" for semester
  chargedInPeriod String?

  reportingTreatment String  @default("cost") // cost | deposit_refundable | excluded
  isWaiverEligible   Boolean @default(true)

  adjustmentOf   String? // Points to original FeeItem id
  adjustmentType String? // course_drop | rate_change | addition | fine | correction

  subjectCode String?
  subjectName String?
  examBoard   String?
  examSession String?

  isActive  Boolean  @default(true)
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([trackerId])
  @@index([userId, feeCategory])
  @@index([trackerId, feeCategory, coveragePeriod])
}

// Section 8: Waiver — scholarship, discount, or fee reduction
model Waiver {
  id        String  @id @default(cuid())
  trackerId String
  tracker   Tracker @relation(fields: [trackerId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  label       String // "Merit scholarship", "Sibling discount"
  waiverType  String // flat | percentage
  amountMinor Int? // For flat waivers
  percentage  Int? // For percentage waivers (20 = 20%)

  appliesTo   String // total | fee_category | fee_item
  feeCategory String? // If appliesTo = fee_category
  feeItemId   String? // If appliesTo = fee_item

  resolvedMinor Int @default(0) // System-computed actual reduction
  priority      Int @default(0) // Lower = applied first

  condition    String? // full_payment_discount | cgpa_threshold | null
  conditionMet Boolean @default(true)

  isActive      Boolean   @default(true)
  reason        String?
  effectiveDate DateTime?
  createdAt     DateTime  @default(now())

  @@index([trackerId])
}

// ═══════════════════════════════════════════════════════════════════════════
// INSTITUTION DATA CENTER — curated, global reference templates (Phase 1)
//
// These are NOT user-scoped. They are read-only reference data the onboarding
// flow searches. A user's `Entity` row is the INSTANCE that optionally points
// at (Institution, Branch, Section) via the nullable soft-link columns on Entity.
// Three-dimensional addressing: Institution (identity) × Branch (location) × Section (program).
// ═══════════════════════════════════════════════════════════════════════════

// Curated canonical identity — the brand/charter (e.g. "Monipur High School and College")
model Institution {
  id         String   @id @default(cuid())
  name       String
  nameBn     String?
  aliases    String[] @default([]) // ["BRACU","ব্র্যাক","Brac Uni"] for search
  type       String // school | college | university | coaching | cadet | residential_school_college | madrasa
  eduLevel   String? // coarse level hint
  division   String?
  district   String?
  area       String?
  trustLevel String   @default("approximate") // verified | approximate | community_reported
  metadata   Json? // capability flags, calendar profile hints, etc.
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  branches Branch[]

  @@index([type])
  @@index([district])
}

// A physical campus/location of an Institution (e.g. "Monipur — Mirpur-2 Main Campus")
model Branch {
  id            String      @id @default(cuid())
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  name          String
  nameBn        String?
  isPrimary     Boolean     @default(false)
  division      String?
  district      String?
  area          String?
  metadata      Json?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  sections Section[]

  @@index([institutionId])
}

// An academic program type offered at a branch (e.g. "School Section, Classes 1-10")
model Section {
  id              String   @id @default(cuid())
  branchId        String
  branch          Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  name            String
  nameBn          String?
  sectionType     String? // school | college | undergraduate | coaching-course | cadet-junior | ...
  eduLevel        String?
  classRangeFrom  String? // "Class 1" / "Year 1" / "HSC 1st Year"
  classRangeTo    String? // "Class 10 (SSC)" / "Year 4"
  residencePolicy String   @default("none") // none | optional | mandatory | phased
  metadata        Json? // feeKit hints, calendarProfileId, residence variants
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([branchId])
}

// ═══════════════════════════════════════════════════════════════════════════
// RECURRING PAYMENTS ENGINE (Phase 3)
//
// A RecurringSchedule defines a monthly/quarterly/yearly charge (rent, school
// tuition, coaching fee). PaymentSlots are the materialized per-period instances
// (idempotent via UNIQUE(scheduleId, period)). ScheduleVersion records amount
// changes over time. AdvancePayment models pre-paid months. Coexists with the
// legacy lazy obligationGenerator — slots are additive and opt-in.
// ═══════════════════════════════════════════════════════════════════════════

model RecurringSchedule {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  trackerId   String? // optional link to a Tracker
  entityId    String? // optional link to an Entity (residence/institution)
  category    String // rent | school_tuition | coaching_monthly | ...
  label       String
  cadence     String   @default("MONTHLY") // MONTHLY | QUARTERLY | YEARLY
  dueDay      Int      @default(1) // 1-28, clamped to short months
  amountMinor Int // current expected amount (also tracked via ScheduleVersion)
  startDate   DateTime
  endDate     DateTime? // null = open-ended
  autoCreate  Boolean  @default(true) // false = manual mode (no auto slots)
  isActive    Boolean  @default(true)
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  versions ScheduleVersion[]
  slots    PaymentSlot[]
  advances AdvancePayment[]

  @@index([userId, isActive])
  @@index([entityId])
  @@index([trackerId])
}

model ScheduleVersion {
  id            String            @id @default(cuid())
  scheduleId    String
  schedule      RecurringSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  amountMinor   Int
  effectiveFrom DateTime
  reason        String?
  createdAt     DateTime          @default(now())

  @@index([scheduleId])
}

model PaymentSlot {
  id            String            @id @default(cuid())
  scheduleId    String
  schedule      RecurringSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  userId        String // scalar (cascades via schedule → user)
  period        String // canonical "YYYY-MM" (or "YYYY-Qn" / "YYYY")
  dueDate       DateTime
  expectedMinor Int
  status        String            @default("PENDING") // PENDING | PAID | PAID_ADVANCE | SKIPPED | VOID
  origin        String            @default("AUTO") // AUTO | ADVANCE | MANUAL | BACKFILL
  obligationId  String? // optional link if mirrored as an Obligation
  paidDate      DateTime?
  advanceId     String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@unique([scheduleId, period]) // hard idempotency — cron cannot duplicate
  @@index([userId, status])
  @@index([scheduleId, status])
}

model AdvancePayment {
  id            String            @id @default(cuid())
  scheduleId    String
  schedule      RecurringSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  userId        String
  monthsCovered Int
  amountMinor   Int // total lump sum
  perPeriodMinor Int // floor(total / months); remainder on last covered slot
  startPeriod   String
  endPeriod     String
  paidOn        DateTime
  paidBy        String            @default("SELF") // SELF | PARENT | OTHER
  ledgerEntryId String?
  createdAt     DateTime          @default(now())

  @@index([scheduleId])
}
