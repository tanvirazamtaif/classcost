generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String     @id @default(uuid())
  email             String     @unique
  name              String?
  eduType           String?
  institution       String?
  classLevel        String?
  currency          String     @default("BDT")
  familyCode        String?
  pin               String?
  parentPin         String?
  isLoggedIn        Boolean    @default(false)
  profileComplete   Boolean    @default(false)
  onboardingSkipped Boolean    @default(false)
  profile           Json?
  premiumUntil      DateTime?
  premiumSource     String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  expenses  Expense[]
  semesters Semester[]
  loans     Loan[]
  settings  Settings?
}

model PromoCode {
  id          String    @id @default(uuid())
  code        String    @unique
  description String?
  durationDays Int      @default(30)
  maxUses     Int       @default(100)
  usedCount   Int       @default(0)
  active      Boolean   @default(true)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
}

model Otp {
  id        String   @id @default(uuid())
  email     String
  code      String
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, code])
}

model Expense {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  amount    Float
  note      String?
  date      String
  meta      Json?
  createdAt DateTime @default(now())
}

model Semester {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  courses   Json     @default("[]")
  dropped   Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Loan {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  loanType          String
  purpose           String?
  principal         Float
  annualRate        Float
  tenureMonths      Int
  gracePeriodMonths Int      @default(0)
  lender            String?
  payments          Json     @default("[]")
  startDate         String?
  createdAt         DateTime @default(now())
}

model Settings {
  id            String @id @default(uuid())
  userId        String @unique
  user          User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  notifications Json   @default("{\"enabled\":true,\"canteen\":true,\"transport\":true}")
  privacy       Json   @default("{}")
  promotion     Json   @default("{}")
  customModules Json   @default("[]")
}
