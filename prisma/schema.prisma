generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String     @id @default(uuid())
  email             String     @unique
  name              String?
  eduType           String?
  institution       String?
  classLevel        String?
  currency          String     @default("BDT")
  pin               String?
  parentPin         String?
  isLoggedIn        Boolean    @default(false)
  profileComplete    Boolean    @default(false)
  onboardingSkipped  Boolean    @default(false)
  onboardingStep     Int        @default(0)
  onboardingComplete Boolean    @default(false)
  profile           Json?
  premiumUntil      DateTime?
  premiumSource     String?
  lastLoginAt       DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  expenses        Expense[]
  semesters       Semester[]
  loans           Loan[]
  settings        Settings?
  coachingCenters CoachingCenter[]
  batches         Batch[]
  privateTutors   PrivateTutor[]
  clubs           Club[]
  events          Event[]
  uniforms        Uniform[]
  educationFees   EducationFee[]
  housings        Housing[]
}

model PromoCode {
  id          String    @id @default(uuid())
  code        String    @unique
  description String?
  durationDays Int      @default(30)
  maxUses     Int       @default(100)
  usedCount   Int       @default(0)
  active      Boolean   @default(true)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
}

model Otp {
  id        String   @id @default(uuid())
  email     String
  code      String
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, code])
}

model Expense {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  amount    Float
  note      String?
  date      String
  meta      Json?
  createdAt DateTime @default(now())
}

model Semester {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  courses   Json     @default("[]")
  dropped   Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Loan {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  loanType          String
  purpose           String?
  principal         Float
  annualRate        Float
  tenureMonths      Int
  gracePeriodMonths Int      @default(0)
  lender            String?
  payments          Json     @default("[]")
  startDate         String?
  createdAt         DateTime @default(now())
}

model Settings {
  id            String @id @default(uuid())
  userId        String @unique
  user          User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  notifications Json   @default("{\"enabled\":true,\"canteen\":true,\"transport\":true}")
  privacy       Json   @default("{}")
  promotion     Json   @default("{}")
  customModules Json   @default("[]")
}

model CoachingCenter {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  monthlyFee Float
  totalMonths Int?
  monthsPaid  Int     @default(0)
  startDate  DateTime
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Batch {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  fee       Float
  frequency String
  isPaid    Boolean   @default(false)
  startDate DateTime
  endDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model PrivateTutor {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tutorName      String
  subject        String
  monthlyFee     Float
  paymentType    String
  sessionsPerWeek Int?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Club {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  institutionName String    @default("")
  name            String
  data            Json?
  fee             Float?
  frequency       String?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Event {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  amount    Float
  date      DateTime
  category  String
  isPaid    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Uniform {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  purchaseDate DateTime
  description  String?
  amount       Float
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model EducationFee {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  feeType   String
  data      Json      // Full complex fee object (payments, periodStatus, installments, etc.)
  isDeleted Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Housing {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  housingType String
  name        String
  data        Json      // Full setup object: monthlyRent, deposit, moveInDate, status, etc.
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
